# Denon Dashboard Configuration
# Copy to .env and adjust values

# IP address of your Denon AVR receiver (required)
DENON_HOST=192.168.1.100

# Telnet control port (default: 23)
DENON_TELNET_PORT=23

# Display name for the receiver
DENON_DEVICE_NAME=Denon AVR

# Zone display names
DENON_ZONE1_NAME=Main Zone
DENON_ZONE2_NAME=Zone 2

# Custom source names as JSON (maps protocol codes to your display names)
# Find your source codes by checking the telnet output (SI? command)
# Common codes: GAME, BD, TV, SAT/CBL, MPLAY, NET, AUX1, AUX2, BT, CD, TUNER, DVD, PHONO
DENON_SOURCE_NAMES={}
# Example:
# DENON_SOURCE_NAMES={"GAME":"Game Console","TV":"TV Audio","BD":"Blu-ray","NET":"Streaming","AUX1":"PC/Console"}

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
